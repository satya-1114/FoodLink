<section class="py-4">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-1">Donor Dashboard</h2>
        <p class="text-muted mb-0">Welcome, <%= profile ? profile.name : currentUser.name %>.</p>
      </div>
      <a href="/donor/donations/new" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> Create Donation
      </a>
    </div>

    <div class="row g-3">
      <div class="col-md-4">
        <div class="card shadow-sm border-0"><div class="card-body">
          <div class="text-muted small">Total Donations</div>
          <div class="display-6 fw-bold text-success"><%= stats.totalDonations %></div>
        </div></div>
      </div>
      <div class="col-md-4">
        <div class="card shadow-sm border-0"><div class="card-body">
          <div class="text-muted small">Accepted</div>
          <div class="display-6 fw-bold text-primary"><%= stats.accepted %></div>
        </div></div>
      </div>
      <div class="col-md-4">
        <div class="card shadow-sm border-0"><div class="card-body">
          <div class="text-muted small">Pending</div>
          <div class="display-6 fw-bold text-warning"><%= stats.pending %></div>
        </div></div>
      </div>
    </div>

    <div class="card shadow-sm border-0 mt-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="fw-semibold mb-0">Recent Donations</h5>
          <a href="/donor/donations" class="small">View all →</a>
        </div>
        <% if (!recent.length) { %>
          <p class="text-muted mb-0">No donations yet. <a href="/donor/donations/new">Create your first one</a>.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="text-muted small">
                <tr><th>Food</th><th>Qty</th><th>Status</th><th>Created</th><th></th></tr>
              </thead>
              <tbody>
                <% recent.forEach(function(d){ %>
                  <tr>
                    <td><%= d.foodName %></td>
                    <td><%= d.quantity %></td>
                    <td><span class="badge bg-secondary"><%= d.status %></span></td>
                    <td class="small text-muted"><%= new Date(d.createdAt).toLocaleString() %></td>
                    <td class="text-end"><a href="/donor/donations/<%= d.id %>" class="btn btn-sm btn-outline-secondary">View</a></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
