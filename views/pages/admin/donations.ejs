<section class="py-4">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3 class="fw-bold mb-0">Manage Donations</h3>
      <a href="/admin/dashboard" class="btn btn-sm btn-outline-secondary">← Dashboard</a>
    </div>

    <form class="row g-2 mb-3" method="GET" action="/admin/donations">
      <div class="col-md-3">
        <input type="text" class="form-control" name="q" value="<%= filters.q %>" placeholder="Search food name…" />
      </div>
      <div class="col-md-2">
        <select class="form-select" name="status">
          <option value="">All statuses</option>
          <% Object.values(statuses).forEach(function(s) { %>
            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
          <% }); %>
        </select>
      </div>
      <div class="col-md-2">
        <select class="form-select" name="vegType">
          <option value="">Any type</option>
          <option value="Veg"     <%= filters.vegType === 'Veg' ? 'selected' : '' %>>Veg</option>
          <option value="Non-Veg" <%= filters.vegType === 'Non-Veg' ? 'selected' : '' %>>Non-Veg</option>
        </select>
      </div>
      <div class="col-md-2">
        <input type="text" class="form-control" name="city" value="<%= filters.city %>" placeholder="City" />
      </div>
      <div class="col-md-3 d-grid">
        <button class="btn btn-success">Filter</button>
      </div>
    </form>

    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Food</th><th>Category</th><th>Type</th>
              <th>City</th><th>Status</th><th>Created</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!result.items.length) { %>
              <tr><td colspan="7" class="text-center text-muted py-4">No donations found.</td></tr>
            <% } %>
            <% result.items.forEach(function(d) { %>
              <tr>
                <td><%= d.foodName %></td>
                <td class="small text-muted"><%= d.foodCategory %></td>
                <td><span class="badge bg-light text-dark"><%= d.vegType %></span></td>
                <td class="small text-capitalize"><%= d.city || '—' %></td>
                <td><span class="badge bg-secondary"><%= d.status %></span></td>
                <td class="small text-muted"><%= new Date(d.createdAt).toLocaleDateString() %></td>
                <td class="text-end">
                  <a href="/admin/donations/<%= d.id %>" class="btn btn-sm btn-outline-secondary">View</a>
                  <form method="POST" action="/admin/donations/<%= d.id %>?_method=DELETE" class="d-inline"
                        onsubmit="return confirm('Delete this donation permanently?');">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <%- include('../../partials/pagination', { result: result, query: query, basePath: '/admin/donations' }) %>
  </div>
</section>
