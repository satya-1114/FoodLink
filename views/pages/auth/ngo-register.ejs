<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-9">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <h3 class="fw-bold mb-1"><i class="bi bi-building text-success"></i> Register Your NGO</h3>
            <p class="text-muted small mb-4">Join FoodLink to receive food donations.</p>

            <%- include('../../partials/form-errors', { errors: errors }) %>

            <form method="POST" action="/ngo/register" novalidate>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Contact Person Name</label>
                  <input type="text" name="name" required minlength="2" maxlength="80"
                         value="<%= formData.name || '' %>" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Organization Name</label>
                  <input type="text" name="organizationName" required minlength="2" maxlength="120"
                         value="<%= formData.organizationName || '' %>" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Registration Number</label>
                  <input type="text" name="registrationNumber" required minlength="2" maxlength="60"
                         value="<%= formData.registrationNumber || '' %>" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Email</label>
                  <input type="email" name="email" required maxlength="254"
                         value="<%= formData.email || '' %>" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Phone</label>
                  <input type="tel" name="phone" required pattern="[0-9+\-\s()]{7,20}"
                         value="<%= formData.phone || '' %>" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Address</label>
                  <input type="text" name="address" required minlength="5" maxlength="250"
                         value="<%= formData.address || '' %>" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Password</label>
                  <input type="password" name="password" required minlength="8" maxlength="128"
                         class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Confirm Password</label>
                  <input type="password" name="confirmPassword" required minlength="8" maxlength="128"
                         class="form-control" />
                </div>
              </div>
              <button type="submit" class="btn btn-success w-100 mt-4">Register NGO</button>
            </form>

            <hr />
            <div class="text-center small">
              Already registered? <a href="/ngo/login">Login</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
