<section class="py-4">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold mb-0">My Profile</h2>
      <a href="/ngo/profile/edit" class="btn btn-outline-success">
        <i class="bi bi-pencil-square me-1"></i> Edit Profile
      </a>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-3">Contact Name</dt><dd class="col-sm-9"><%= profile.name %></dd>
          <dt class="col-sm-3">Organization</dt><dd class="col-sm-9"><%= profile.organizationName %></dd>
          <dt class="col-sm-3">Reg. Number</dt><dd class="col-sm-9"><%= profile.registrationNumber %></dd>
          <dt class="col-sm-3">Email</dt><dd class="col-sm-9"><%= profile.email %></dd>
          <dt class="col-sm-3">Phone</dt><dd class="col-sm-9"><%= profile.phone || '—' %></dd>
          <dt class="col-sm-3">Address</dt><dd class="col-sm-9"><%= profile.address || '—' %></dd>
          <dt class="col-sm-3">Joined</dt>
          <dd class="col-sm-9"><%= new Date(profile.createdAt).toLocaleDateString() %></dd>
        </dl>
      </div>
    </div>
  </div>
</section>
