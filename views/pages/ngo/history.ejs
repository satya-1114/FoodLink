<%
  function badgeClass(status) {
    switch (status) {
      case 'Pending': return 'bg-warning text-dark';
      case 'Accepted': return 'bg-primary';
      case 'Collected': return 'bg-success';
      case 'Expired': return 'bg-secondary';
      case 'Cancelled': return 'bg-dark';
      default: return 'bg-light text-dark';
    }
  }
%>
<section class="py-4">
  <div class="container">
    <h2 class="fw-bold mb-4">Donation History</h2>
    <% if (!donations.length) { %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-clock-history display-4 text-muted"></i>
          <p class="text-muted mt-3 mb-0">No donations yet in your history.</p>
        </div>
      </div>
    <% } else { %>
      <div class="card shadow-sm border-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Food</th><th>Category</th><th>Qty</th><th>Status</th>
                <th>Accepted</th><th>Collected</th><th class="text-end">View</th>
              </tr>
            </thead>
            <tbody>
              <% donations.forEach(function(d){ %>
                <tr>
                  <td class="fw-semibold"><%= d.foodName %></td>
                  <td><%= d.foodCategory %></td>
                  <td><%= d.quantity %></td>
                  <td><span class="badge <%= badgeClass(d.status) %>"><%= d.status %></span></td>
                  <td class="small"><%= d.acceptedAt ? new Date(d.acceptedAt).toLocaleString() : '—' %></td>
                  <td class="small"><%= d.collectedAt ? new Date(d.collectedAt).toLocaleString() : '—' %></td>
                  <td class="text-end">
                    <a href="/ngo/donations/<%= d.id %>" class="btn btn-sm btn-outline-secondary">View</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</section>
