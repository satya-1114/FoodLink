<%
  function badgeClass(status) {
    switch (status) {
      case 'Pending': return 'bg-warning text-dark';
      case 'Accepted': return 'bg-primary';
      case 'Collected': return 'bg-success';
      case 'Expired': return 'bg-secondary';
      case 'Cancelled': return 'bg-dark';
      default: return 'bg-light text-dark';
    }
  }
%>
<section class="py-4">
  <div class="container">
    <h2 class="fw-bold mb-4">Accepted Donations (Pending Pickup)</h2>
    <% if (!donations.length) { %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-inbox display-4 text-muted"></i>
          <p class="text-muted mt-3 mb-0">
            No accepted donations awaiting pickup. <a href="/ngo/donations">Browse available donations</a>.
          </p>
        </div>
      </div>
    <% } else { %>
      <div class="card shadow-sm border-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Food</th><th>Qty</th><th>Pickup</th><th>Accepted</th>
                <th>Status</th><th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% donations.forEach(function(d){ %>
                <tr>
                  <td class="fw-semibold"><%= d.foodName %></td>
                  <td><%= d.quantity %></td>
                  <td class="small"><%= d.pickupTime ? new Date(d.pickupTime).toLocaleString() : '—' %></td>
                  <td class="small text-muted"><%= d.acceptedAt ? new Date(d.acceptedAt).toLocaleString() : '—' %></td>
                  <td><span class="badge <%= badgeClass(d.status) %>"><%= d.status %></span></td>
                  <td class="text-end">
                    <a href="/ngo/donations/<%= d.id %>" class="btn btn-sm btn-outline-secondary">View</a>
                    <form method="POST" action="/ngo/donations/<%= d.id %>/collected"
                          class="d-inline" onsubmit="return confirm('Mark this donation as Collected?');">
                      <button class="btn btn-sm btn-success" type="submit">
                        <i class="bi bi-check2-circle me-1"></i> Mark Collected
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</section>
