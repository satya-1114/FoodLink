<section class="py-4">
  <div class="container">
    <h2 class="fw-bold mb-4">Edit Profile</h2>
    <%- include('../../partials/form-errors', { errors: errors }) %>
    <div class="card shadow-sm border-0">
      <div class="card-body">
        <form method="POST" action="/ngo/profile/edit" novalidate>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Contact Name</label>
              <input type="text" name="name" required minlength="2" maxlength="80"
                     value="<%= formData.name || '' %>" class="form-control" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Organization Name</label>
              <input type="text" name="organizationName" required minlength="2" maxlength="120"
                     value="<%= formData.organizationName || '' %>" class="form-control" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Registration Number</label>
              <input type="text" name="registrationNumber" required minlength="2" maxlength="60"
                     value="<%= formData.registrationNumber || '' %>" class="form-control" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Email</label>
              <input type="email" class="form-control" value="<%= formData.email || '' %>" disabled />
              <div class="form-text">Email cannot be changed.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Phone</label>
              <input type="tel" name="phone" required pattern="[0-9+\-\s()]{7,20}"
                     value="<%= formData.phone || '' %>" class="form-control" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Address</label>
              <input type="text" name="address" required minlength="5" maxlength="250"
                     value="<%= formData.address || '' %>" class="form-control" />
            </div>
          </div>
          <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-success">Save Changes</button>
            <a href="/ngo/profile" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
