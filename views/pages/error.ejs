<section class="py-5">
  <div class="container text-center py-5">
    <h1 class="display-3 fw-bold text-danger"><%= status %></h1>
    <h2 class="fw-semibold"><%= title %></h2>
    <p class="text-muted"><%= message %></p>
    <% if (stack) { %>
      <pre class="text-start bg-dark text-light p-3 rounded small mt-4" style="overflow:auto"><%= stack %></pre>
    <% } %>
    <a href="/" class="btn btn-success mt-3"><i class="bi bi-house-door me-1"></i> Go Home</a>
  </div>
</section>
