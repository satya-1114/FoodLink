<%
  function badgeClass(status) {
    switch (status) {
      case 'Pending': return 'bg-warning text-dark';
      case 'Accepted': return 'bg-primary';
      case 'Collected': return 'bg-success';
      case 'Expired': return 'bg-secondary';
      case 'Cancelled': return 'bg-dark';
      default: return 'bg-light text-dark';
    }
  }
%>
<section class="py-4">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold mb-0">My Donations</h2>
      <a href="/donor/donations/new" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> New Donation
      </a>
    </div>

    <% if (!donations.length) { %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-inbox display-3 text-muted"></i>
          <p class="text-muted mt-3 mb-0">You haven't posted any donations yet.</p>
        </div>
      </div>
    <% } else { %>
      <div class="card shadow-sm border-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Food</th><th>Category</th><th>Qty</th><th>Status</th>
                <th>Pickup</th><th>Expiry</th><th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% donations.forEach(function(d){ %>
                <tr>
                  <td class="fw-semibold"><%= d.foodName %></td>
                  <td><%= d.foodCategory %> <span class="text-muted small">(<%= d.vegType %>)</span></td>
                  <td><%= d.quantity %></td>
                  <td><span class="badge <%= badgeClass(d.status) %>"><%= d.status %></span></td>
                  <td class="small"><%= d.pickupTime ? new Date(d.pickupTime).toLocaleString() : '—' %></td>
                  <td class="small"><%= d.expiryTime ? new Date(d.expiryTime).toLocaleString() : '—' %></td>
                  <td class="text-end">
                    <a href="/donor/donations/<%= d.id %>" class="btn btn-sm btn-outline-secondary">View</a>
                    <% if (d.status === STATUS.PENDING) { %>
                      <form method="POST" action="/donor/donations/<%= d.id %>/delete"
                            class="d-inline" onsubmit="return confirm('Delete this donation?');">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</section>
