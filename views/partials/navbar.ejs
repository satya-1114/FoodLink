<nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-basket2-fill me-1"></i> FoodLink
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav ms-auto align-items-lg-center">
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/about' ? 'active' : '' %>" href="/about">About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>" href="/contact">Contact</a>
        </li>

        <% if (!currentUser) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">Login</a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/donor/login">Donor Login</a></li>
              <li><a class="dropdown-item" href="/ngo/login">NGO Login</a></li>
              <li><hr class="dropdown-divider" /></li>
              <li><a class="dropdown-item" href="/admin/login">Admin Login</a></li>
            </ul>
          </li>
          <li class="nav-item ms-lg-2">
            <a class="btn btn-light btn-sm fw-semibold" href="/donor/register">Get Started</a>
          </li>
        <% } else { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
              <i class="bi bi-person-circle me-1"></i><%= currentUser.name || currentUser.email %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/<%= currentUser.role %>/dashboard">Dashboard</a></li>
              <% if (currentUser.role === 'donor') { %>
                <li><a class="dropdown-item" href="/donor/donations">My Donations</a></li>
                <li><a class="dropdown-item" href="/donor/profile">My Profile</a></li>
              <% } else if (currentUser.role === 'ngo') { %>
                <li><a class="dropdown-item" href="/ngo/donations">Browse Donations</a></li>
                <li><a class="dropdown-item" href="/ngo/accepted">Accepted</a></li>
                <li><a class="dropdown-item" href="/ngo/history">History</a></li>
                <li><a class="dropdown-item" href="/ngo/profile">My Profile</a></li>
              <% } else if (currentUser.role === 'admin') { %>
                <li><a class="dropdown-item" href="/admin/users">Manage Users</a></li>
                <li><a class="dropdown-item" href="/admin/donations">Manage Donations</a></li>
              <% } %>

              <li><hr class="dropdown-divider" /></li>
              <li>
                <form action="/auth/logout" method="POST" class="m-0">
                  <button class="dropdown-item" type="submit">Logout</button>
                </form>
              </li>
            </ul>

          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
