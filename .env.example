# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Deployment target: leave empty for local, set to 'aws' on AWS-hosted instances.
DEPLOY_TARGET=

# Session
SESSION_SECRET=replace_with_a_long_random_string_at_least_32_chars
SESSION_NAME=foodlink.sid

# ----- Firebase (used when DB_DRIVER=firestore) -----
FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ----- Driver selection -----
# DB_DRIVER:            firestore | dynamodb
# STORAGE_DRIVER:       local     | s3
# NOTIFICATIONS_DRIVER: console   | sns
DB_DRIVER=firestore
STORAGE_DRIVER=local
NOTIFICATIONS_DRIVER=console

# ----- AWS credentials -----
# Leave AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY empty on EC2 / ECS /
# Lambda to use the attached IAM role (recommended in production).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ----- Amazon S3 (when STORAGE_DRIVER=s3) -----
S3_BUCKET=foodlink-uploads
# Set to "false" for a private bucket; getImageUrl() will return signed URLs.
S3_PUBLIC_READ=true

# ----- Amazon DynamoDB (when DB_DRIVER=dynamodb) -----
DYNAMODB_TABLE_USERS=foodlink_users
DYNAMODB_TABLE_DONATIONS=foodlink_donations

# ----- Amazon SNS (when NOTIFICATIONS_DRIVER=sns) -----
SNS_TOPIC_ARN=

# Logs
LOG_DIR=./logs
